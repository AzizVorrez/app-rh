# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Any Postgres provider works. Recommended for Vercel: Neon (neon.tech).
# Use the POOLED connection string (it must allow many short-lived connections).
# Neon example:     postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require
# Supabase example:  postgresql://postgres.xxx:pass@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ─── Admin (RH) access ───────────────────────────────────────────────────
# Initial admin password. Used the first time only, then a hash is stored in
# the DB and can be changed from the dashboard (Paramètres). Change this!
ADMIN_PASSWORD="izichange2026"

# Secret used to sign the admin session cookie (JWT).
# Generate one:  openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
